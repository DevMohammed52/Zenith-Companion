{
  "name": "zenith-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "concurrently \"node --env-file=.env scraper.mjs\" \"next dev\"",
    "build": "node scripts/rebuild-usage-map.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "rebuild": "node scripts/rebuild-usage-map.mjs",
    "scrape": "SCRAPE_ONCE=true node scraper.mjs",
    "scrape:priority": "SCRAPE_ONCE=true node scraper.mjs --priority"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "lucide-react": "^1.13.0",
    "typescript": "^5"
  }
}
